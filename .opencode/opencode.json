{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "docs/PROJECT_CONTEXT.md",
    "docs/CURRENT_STATE.md",
    "docs/ARCHITECTURE.md",
    "docs/INTEGRATION_MAP.md",
    "docs/DECISIONS.md"
  ],
  "mcp": {
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp",
      "enabled": true
    },
    "render": {
      "type": "remote",
      "url": "https://mcp.render.com/mcp",
      "enabled": true
    },
    "firecrawl": {
      "type": "remote",
      "url": "https://mcp.firecrawl.dev/v2/mcp",
      "enabled": true
    },
    "n8n": {
      "type": "remote",
      "url": "https://saleems.app.n8n.cloud/mcp-server/http",
      "enabled": true
    },
    "smartlead": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.smartlead.ai/sse?user_api_key={env:SMARTLEAD_API_KEY}"
      ],
      "enabled": true
    }
  }
}
