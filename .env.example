# CampaignOps Kernel v1 — Environment Variables

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Direct Postgres connection for staging/local Docker
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/campaignops

# OpenAI / OpenRouter
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Smartlead / Instantly / HubSpot
EMAIL_PROVIDER=smartlead
SMARTLEAD_API_KEY=...
INSTANTLY_API_KEY=...
HUBSPOT_API_KEY=...

# Calendly
CALENDLY_API_KEY=...

# n8n
N8N_WEBHOOK_URL=http://localhost:5678
N8N_API_KEY=...

# App
API_PORT=8000
ENVIRONMENT=development
